# ─── Infra ──────────────────────────────────────────────────────────────────

# NATS operator key that signs every account/user JWT — the most sensitive
# credential Infra holds. Leave blank to auto-generate on first boot (persisted
# to ./store). For anything beyond a trial, generate your own with `nats nkey`.
OPERATOR_SEED=

# Shared HMAC secret for Infra's API. The inspector panel MUST use the same value
# (see inspector/.env -> INFLOW_INFRA_JWT_SECRET), so set it explicitly rather
# than letting Infra randomize it. Generate one, e.g.:
#   openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 60
API_JWT_SECRET=

# Only for a paid/sponsored license. Leave blank for free standalone use.
INFRA_CLUSTER=

# ─── Fractal ────────────────────────────────────────────────────────────────

FRACTAL_NAME=fractal-cpu-1
FRACTAL_TAGS=default

# Infra's built-in default portal path is "abc". Only change this if you created
# a custom portal (then copy its /register/<path> URL from Infra's logs).
FRACTAL_REGISTER_URL=http://inflow-infra:8022/register/abc
